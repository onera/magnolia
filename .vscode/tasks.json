{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run All Debugs",
            "type": "shell",
            "command": "wsl",
            "args": [
                "bash", "c_implementation/debug/run_debug.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}